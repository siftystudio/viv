// A character slips a secret note under someone's door
action leave-secret-note:
    gloss: "@leaver slips a secret note under @recipient's door"
    roles:
        @leaver:
            as: initiator
        @recipient:
            as: character, anywhere
        @secret:
            as: action
            from:
                search query discreet-secret:
                    over: @leaver
        @note:
            as: item, spawn
            spawn: ~createItem("note")
    conditions:
        @leaver.location == @recipient.home
    effects:
        @note inscribe @secret
    reactions:
        queue action read-note:
            with:
                @reader: @recipient
                @note: @note

// The recipient finds and reads the note, learning its secrets
action read-note:
    gloss: "@reader reads @note and learns its secrets"
    roles:
        @reader:
            as: initiator
        @note:
            as: item
    effects:
        @reader inspect @note

// Matches past actions that are sensitive and noteworthy
query discreet-secret:
    tags:
        all: discreet
    salience:
        >=: #HIGH
