// A character confesses a long-held secret to a friend. Note that @confidant will
// automatically learn about @secret as a result of this action, because knowledge
// always propagates for any past actions cast in an action role.
action confess-secret:
    gloss: "@confessor reveals a long-held secret to @confidant"
    roles:
        @confessor:
            as: initiator
        @confidant:
            as: partner
            from: @confessor.friends
        @secret:
            as: action  // @confidant automatically learns about @secret through knowledge propagation
            from:
                search query long-held-secret:
                    over: @confessor
    conditions:
        @confessor.trust[@confidant] >= #HIGH
    effects:
        @confessor.stress -= #MODERATE

// When applied 'over' a character, it matches actions from 5+ years
// ago that they associate with embarrassment.
query long-held-secret:
    salience:
        >=: #HIGH
    associations:
        all: embarrassing
    time:
        before: 5 years ago
