#!/usr/bin/env bash
# bin/viv-plugin-get-plugin-file -- Fetch a plugin-bundled file by name, atomically
#
# Resolves the highest-versioned plugin cache directory and prints the
# requested file. Atomic by design: no slicing, no ranges -- these are
# instructions for Claude and should be fetched whole or not at all.
#
# Works around a Claude Code caching bug where skills run from an older
# version than what's installed.
#
# Usage: viv-plugin-get-plugin-file <name>
#
# Files: main, primer, web-links, writer, fixer, designer, researcher, engineer, critic
#
# For the monorepo map, use viv-plugin-get-monorepo-map -- it now lives
# in the monorepo (at docs/.llm/monorepo-map.md), not in the plugin.

set -euo pipefail

if [ $# -eq 0 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo ""
    echo "Usage: viv-plugin-get-plugin-file <name>"
    echo ""
    echo "Fetches a plugin-bundled file from the latest installed version."
    echo "Files are returned whole -- no slicing or ranges."
    echo ""
    echo "Files:"
    echo "  main          Viv plugin guide -- how to operate as a Viv partner"
    echo "  primer        Viv primer -- language overview, constructs, concepts"
    echo "  web-links     External URLs (docs, registries, marketplaces)"
    echo ""
    echo "For the monorepo map, use viv-plugin-get-monorepo-map."
    echo ""
    echo "Skill references:"
    echo "  writer        Writing Viv code"
    echo "  fixer         Fixing Viv errors"
    echo "  designer      Designing Viv systems"
    echo "  researcher    Researching Viv internals"
    echo "  engineer      Building Viv integrations"
    echo "  critic        Critiquing Viv code"
    echo ""
    echo "Options:"
    echo "  --help        Show this help"
    echo ""
    exit 0
fi

# Handle the deprecated `monorepo-map` name before the cache-population
# checks, so an agent calling the old name on a fresh install still gets
# the redirect to viv-plugin-get-monorepo-map rather than a generic
# "plugin not installed" error.
if [ "$1" = "monorepo-map" ]; then
    echo "" >&2
    echo "The monorepo map is no longer a plugin-bundled file." >&2
    echo "Use viv-plugin-get-monorepo-map instead." >&2
    echo "" >&2
    exit 1
fi

CACHE_DIR="$HOME/.claude/plugins/cache/siftystudio/viv"

if [ ! -d "$CACHE_DIR" ]; then
    echo "" >&2
    echo "Viv plugin is not installed -- no cache directory found." >&2
    echo "" >&2
    exit 1
fi

# Find the highest semver version directory. Strict X.Y.Z filter prevents
# numeric sort from picking `99abc` (coerced to 99) or pre-release
# suffixes (which sort above their stable counterparts).
LATEST=$(
    for entry in "$CACHE_DIR"/*/; do
        name="${entry%/}"
        name="${name##*/}"
        if [[ "$name" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "$name"
        fi
    done | sort -t. -k1,1n -k2,2n -k3,3n | tail -1
)

if [ -z "$LATEST" ]; then
    echo "" >&2
    echo "Plugin cache is empty -- try reinstalling." >&2
    echo "" >&2
    exit 1
fi

DOC_ROOT="$CACHE_DIR/$LATEST"

case "$1" in
    main)
        cat "$DOC_ROOT/docs/agents/main.md"
        ;;
    primer)
        cat "$DOC_ROOT/docs/primer.md"
        ;;
    web-links)
        cat "$DOC_ROOT/docs/web-links.md"
        ;;
    writer)
        cat "$DOC_ROOT/docs/agents/writer.md"
        ;;
    fixer)
        cat "$DOC_ROOT/docs/agents/fixer.md"
        ;;
    designer)
        cat "$DOC_ROOT/docs/agents/designer.md"
        ;;
    researcher)
        cat "$DOC_ROOT/docs/agents/researcher.md"
        ;;
    engineer)
        cat "$DOC_ROOT/docs/agents/engineer.md"
        ;;
    critic)
        cat "$DOC_ROOT/docs/agents/critic.md"
        ;;
    *)
        echo "" >&2
        echo "Unknown file: $1" >&2
        echo "Run viv-plugin-get-plugin-file --help for available files." >&2
        echo "" >&2
        exit 1
        ;;
esac
