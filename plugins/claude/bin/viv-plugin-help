#!/usr/bin/env bash
# bin/viv-plugin-help -- List all available Viv plugin commands
#
# Usage: viv-plugin-help

set -euo pipefail

if [ $# -gt 0 ] && [ "${1:-}" != "--help" ] && [ "${1:-}" != "-h" ]; then
    echo "Unexpected argument: $1" >&2
    echo "Usage: viv-plugin-help" >&2
    exit 1
fi

echo ""
echo "Viv Plugin Commands"
echo "==================="
echo ""
echo "Discovery:"
echo "  viv-plugin-help                          List every plugin command (this output)"
echo "  viv-plugin-orient                        Load primer + guide + state in one call"
echo ""
echo "Plugin files (atomic fetch):"
echo "  viv-plugin-get-plugin-file <name>        Fetch a plugin-bundled file (primer, writer, ...)"
echo "  viv-plugin-get-example [name|--all]      List or fetch idiomatic example Viv files (or --all to print every example)"
echo ""
echo "Monorepo:"
echo "  viv-plugin-get-monorepo-map              Print the monorepo map (keyword-searchable file index)"
echo "  viv-plugin-explore-monorepo ls [path]    List a directory in the monorepo"
echo "  viv-plugin-explore-monorepo grep <pat>   Search the monorepo for a pattern"
echo "  viv-plugin-read-monorepo-file <path>     Print a file from the monorepo"
echo "                                             Optional slicing: [start] [end] or --offset N --limit M"
echo "  viv-plugin-fetch-monorepo [tag]          Download or update the Viv monorepo"
echo "  viv-plugin-fetch-monorepo --check        Check if monorepo is downloaded"
echo "  viv-plugin-fetch-monorepo --path         Print the monorepo directory path"
echo ""
echo "Version checks:"
echo "  viv-plugin-version                       Report the version of the plugin currently running"
echo "  viv-plugin-check-latest                  Report latest published versions of all Viv components"
echo ""
echo "State:"
echo "  viv-plugin-read-state                            Print plugin state"
echo "  viv-plugin-write-state --init '{...}'            Initialize state from JSON"
echo "  viv-plugin-write-state --set <k> <v>             Set a state property"
echo "  viv-plugin-write-state --project <p> <k> <v>     Set a project property"
echo ""
echo "Editor plugins:"
echo "  viv-plugin-install-vscode-extension     Install or --check VS Code extension"
echo "  viv-plugin-install-webstorm-plugin      Install or --check WebStorm plugin"
echo "  viv-plugin-install-sublime-package      Install or --check Sublime Text package"
echo ""
echo "Runtime:"
echo "  viv-plugin-install-runtime              Install or --check the Viv JS runtime"
echo ""
echo "All commands support --help for details."
echo ""

exit 0
