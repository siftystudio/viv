#!/usr/bin/env bash
# bin/viv-plugin-install-sublime-package -- Install the Viv Sublime Text package
#
# Copies the Sublime package source from the plugin's cloned monorepo
# (plugins/sublime/) into Sublime Text's Packages/Viv/ directory.
#
# Usage: viv-plugin-install-sublime-package
#        viv-plugin-install-sublime-package --check

set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo ""
    echo "Usage: viv-plugin-install-sublime-package"
    echo "       viv-plugin-install-sublime-package --check"
    echo ""
    echo "Installs the Viv Sublime Text package by copying its source from"
    echo "the plugin's cloned monorepo into Sublime's Packages/Viv/ directory."
    echo "Use --check to see if Sublime Text and the package are installed."
    echo ""
    exit 0
fi

# Detect Sublime Text Installed Packages directory
DEST=""
if [ -d "$HOME/Library/Application Support/Sublime Text/Installed Packages" ]; then
    DEST="$HOME/Library/Application Support/Sublime Text/Installed Packages"
elif [ -d "$HOME/.config/sublime-text/Installed Packages" ]; then
    DEST="$HOME/.config/sublime-text/Installed Packages"
elif [ -d "$HOME/.config/sublime-text-3/Installed Packages" ]; then
    DEST="$HOME/.config/sublime-text-3/Installed Packages"
fi

if [ "${1:-}" = "--check" ]; then
    if [ -z "$DEST" ]; then
        echo "Sublime Text: not installed"
        exit 0
    fi
    echo "Sublime Text: installed"
    # Check both Installed Packages (zip) and Packages (extracted) locations
    PACKAGES_DIR=$(dirname "$DEST")/Packages
    if [ -f "$DEST/Viv.sublime-package" ] || [ -d "$PACKAGES_DIR/Viv" ]; then
        echo "Viv package: installed"
    else
        echo "Viv package: not installed"
    fi
    exit 0
fi

if [ $# -gt 0 ]; then
    echo "Unexpected argument: $1" >&2
    echo "Usage: viv-plugin-install-sublime-package [--check | --help]" >&2
    exit 1
fi

if [ -z "$DEST" ]; then
    echo "" >&2
    echo "Could not find Sublime Text's Installed Packages directory." >&2
    echo "Is Sublime Text installed?" >&2
    echo "" >&2
    exit 1
fi

PACKAGES_DIR=$(dirname "$DEST")/Packages
EXTRACT_DIR="$PACKAGES_DIR/Viv"

MONOREPO_SRC="$HOME/.claude/plugins/data/viv-siftystudio/viv-monorepo/plugins/sublime"

if [ ! -d "$MONOREPO_SRC" ]; then
    echo "" >&2
    echo "Monorepo not found. Run viv-plugin-fetch-monorepo or /viv:setup first." >&2
    echo "" >&2
    exit 1
fi

echo ""
echo "Installing Viv Sublime Text package from monorepo..."
# Clear any prior install so renamed or deleted files don't linger as
# stale state. Mirrors the clean-then-extract pattern in viv-plugin-fetch-monorepo.
rm -rf "$EXTRACT_DIR"
mkdir -p "$EXTRACT_DIR"
# Use the `/.` suffix to copy every entry including dotfiles. `cp -rP src/* dst`
# would skip dotfiles like `.no-sublime-package`, which Sublime requires to
# keep the extracted directory as-is rather than repacking it into a zip.
# -P preserves symlinks instead of following them. The monorepo download
# already scrubs symlinks, so this is defensive: any symlinks that somehow
# survive would be copied as broken links rather than dereferenced into the
# user's editor plugin directory.
cp -rP "$MONOREPO_SRC"/. "$EXTRACT_DIR/"

if [ -f "$EXTRACT_DIR/Viv.sublime-syntax" ]; then
    echo "Installed to $EXTRACT_DIR"
    echo ""
else
    echo "" >&2
    echo "Installation failed." >&2
    echo "" >&2
    exit 1
fi
