#!/usr/bin/env bash
# bin/viv-plugin-explore-monorepo -- Locate files in the Viv monorepo
#
# Provides ls and grep access to the local Viv monorepo copy for finding
# files. To read file contents, use viv-plugin-read-monorepo-file.
# All paths are relative to the monorepo root.
#
# Usage:
#   viv-plugin-explore-monorepo ls [relpath]                       List a directory
#   viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]   Search for a pattern
#   viv-plugin-explore-monorepo --help                             Show this help

set -euo pipefail

MONOREPO_DIR="$HOME/.claude/plugins/data/viv-siftystudio/viv-monorepo"

show_help() {
    echo ""
    echo "Usage: viv-plugin-explore-monorepo <command> [args]"
    echo ""
    echo "Locate files in the local Viv monorepo copy (ls and grep only). To read"
    echo "file contents, use viv-plugin-read-monorepo-file."
    echo ""
    echo "All paths are relative to the monorepo root."
    echo ""
    echo "Commands:"
    echo "  ls [relpath]                              List a directory (default: root)"
    echo "  grep [flags] <pattern> [relpath]          Search for a pattern."
    echo "                                              -A N  include N lines after each match"
    echo "                                              -B N  include N lines before each match"
    echo "                                              -i    case-insensitive match"
    echo "                                              -l    list matching files only"
    echo "                                              -c    count matches per file"
    echo "  --help                                    Show this help"
    echo ""
    echo "Start by loading the monorepo map to find what you need:"
    echo "  viv-plugin-get-monorepo-map"
    echo ""
    echo "The map is a curated guide with descriptions and keywords for every"
    echo "important file. Find the path you need there, then use ls/grep here"
    echo "to explore the tree, and viv-plugin-read-monorepo-file to read content."
    echo ""
}

check_monorepo() {
    if [ ! -d "$MONOREPO_DIR" ]; then
        echo "" >&2
        echo "Monorepo not found. Run /viv:setup or viv-plugin-fetch-monorepo first." >&2
        echo "" >&2
        exit 1
    fi
}

# Reject relpaths containing `..` segments or absolute paths, then canonicalize
# the resolved target and confirm it stays inside $MONOREPO_DIR. The lexical
# check catches literal traversal; the canonicalization check catches symlink
# escape (a symlink under the monorepo pointing at /etc/passwd, for instance).
validate_relpath() {
    local relpath="$1"
    case "$relpath" in
        ..|../*|*/../*|*/..)
            echo "Refusing path traversal: $relpath" >&2
            exit 1
            ;;
        /*)
            echo "Refusing absolute path: $relpath" >&2
            exit 1
            ;;
    esac
    local target="$MONOREPO_DIR/$relpath"
    local resolved_root resolved_target
    resolved_root=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$MONOREPO_DIR" 2>/dev/null || true)
    resolved_target=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$target" 2>/dev/null || true)
    if [ -z "$resolved_root" ] || [ -z "$resolved_target" ]; then
        echo "Refusing path (could not canonicalize): $relpath" >&2
        exit 1
    fi
    case "$resolved_target" in
        "$resolved_root"|"$resolved_root"/*) ;;
        *)
            echo "Refusing symlink escape: $relpath resolves outside the monorepo" >&2
            exit 1
            ;;
    esac
}

if [ $# -eq 0 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    show_help
    exit 0
fi

check_monorepo

case "$1" in
    ls)
        relpath="${2:-.}"
        validate_relpath "$relpath"
        target="$MONOREPO_DIR/$relpath"
        if [ ! -e "$target" ]; then
            echo "Not found: $relpath" >&2
            exit 1
        fi
        if [ ! -d "$target" ]; then
            echo "Not a directory: $relpath (use viv-plugin-read-monorepo-file for files)" >&2
            exit 1
        fi
        (cd "$target" && ls)
        ;;
    grep)
        shift
        grep_args=()
        positional=()
        while [ $# -gt 0 ]; do
            case "$1" in
                -A|-B)
                    if [ $# -lt 2 ]; then
                        echo "Error: $1 requires a numeric argument" >&2
                        exit 1
                    fi
                    if ! [[ "$2" =~ ^[0-9]+$ ]]; then
                        echo "Error: $1 requires a non-negative integer, got: $2" >&2
                        exit 1
                    fi
                    grep_args+=("$1" "$2")
                    shift 2
                    ;;
                -i|-l|-c)
                    grep_args+=("$1")
                    shift
                    ;;
                --)
                    shift
                    while [ $# -gt 0 ]; do
                        positional+=("$1")
                        shift
                    done
                    ;;
                -*)
                    echo "Error: unsupported flag: $1" >&2
                    echo "Supported flags: -A N, -B N, -i, -l, -c" >&2
                    exit 1
                    ;;
                *)
                    positional+=("$1")
                    shift
                    ;;
            esac
        done
        if [ ${#positional[@]} -eq 0 ]; then
            echo "Usage: viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]" >&2
            exit 1
        fi
        if [ ${#positional[@]} -gt 2 ]; then
            echo "Error: too many arguments. Usage: viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]" >&2
            exit 1
        fi
        pattern="${positional[0]}"
        relpath="${positional[1]:-.}"
        validate_relpath "$relpath"
        target="$MONOREPO_DIR/$relpath"
        if [ ! -e "$target" ]; then
            echo "Not found: $relpath" >&2
            exit 1
        fi
        # Escape sed metacharacters in $MONOREPO_DIR (& \ and the | delimiter)
        # before using it in the substitution.
        escaped_dir=$(printf '%s' "$MONOREPO_DIR" | sed 's/[&\\|]/\\&/g')
        grep -rn ${grep_args[@]+"${grep_args[@]}"} -e "$pattern" "$target" 2>/dev/null | sed "s|${escaped_dir}/||" || true
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Run viv-plugin-explore-monorepo --help for usage." >&2
        exit 1
        ;;
esac
