#!/usr/bin/env bash
# bin/viv-plugin-explore-monorepo -- Browse the Viv monorepo
#
# Provides ls, read, and grep access to the local Viv monorepo copy.
# All paths are relative to the monorepo root.
#
# Usage:
#   viv-plugin-explore-monorepo ls [relpath]                       List a directory
#   viv-plugin-explore-monorepo read <relpath> [start] [end]        Print a file (optionally a line range)
#   viv-plugin-explore-monorepo read <relpath> [--offset N] [--limit M]   Same, with flag-style slicing
#   viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]    Search for a pattern
#   viv-plugin-explore-monorepo --help                              Show this help

set -euo pipefail

MONOREPO_DIR="$HOME/.claude/plugins/data/viv-siftystudio/viv-monorepo"

show_help() {
    echo ""
    echo "Usage: viv-plugin-explore-monorepo <command> [args]"
    echo ""
    echo "Browse the local Viv monorepo copy. All paths are relative to the monorepo root."
    echo ""
    echo "Commands:"
    echo "  ls [relpath]                              List a directory (default: root)"
    echo "  read <relpath> [start] [end]              Print a file. Optional line range:"
    echo "                                              read foo.md 10 50  -> lines 10-50"
    echo "                                              read foo.md 10     -> from line 10 to end"
    echo "                                            Equivalent flag-style slicing:"
    echo "                                              read foo.md --offset 10 --limit 41  -> lines 10-50"
    echo "                                              read foo.md --offset 10             -> from line 10 to end"
    echo "                                              read foo.md --limit 20              -> first 20 lines"
    echo "  grep [flags] <pattern> [relpath]          Search for a pattern."
    echo "                                              -A N  include N lines after each match"
    echo "                                              -B N  include N lines before each match"
    echo "                                              -i    case-insensitive match"
    echo "                                              -l    list matching files only"
    echo "                                              -c    count matches per file"
    echo "  --help                                    Show this help"
    echo ""
    echo "Start by loading the monorepo map to find what you need:"
    echo "  viv-plugin-get-doc monorepo-map"
    echo ""
    echo "The map is a curated guide with descriptions and keywords for every"
    echo "important file. Find the path you need there, then use the commands"
    echo "above to access it."
    echo ""
}

check_monorepo() {
    if [ ! -d "$MONOREPO_DIR" ]; then
        echo "" >&2
        echo "Monorepo not found. Run /viv:setup or viv-plugin-fetch-monorepo first." >&2
        echo "" >&2
        exit 1
    fi
}

# Reject relpaths containing `..` segments or absolute paths. Lexical check
# (no canonicalization), so legal filenames like `foo..bar` are still allowed
# while `..`, `../etc/passwd`, and `/etc/passwd` are refused. Symlinks inside
# the monorepo are not followed -- that's enforced by `viv-plugin-fetch-monorepo`.
validate_relpath() {
    local relpath="$1"
    case "$relpath" in
        ..|../*|*/../*|*/..)
            echo "Refusing path traversal: $relpath" >&2
            exit 1
            ;;
        /*)
            echo "Refusing absolute path: $relpath" >&2
            exit 1
            ;;
    esac
}

if [ $# -eq 0 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    show_help
    exit 0
fi

check_monorepo

case "$1" in
    ls)
        relpath="${2:-.}"
        validate_relpath "$relpath"
        target="$MONOREPO_DIR/$relpath"
        if [ ! -e "$target" ]; then
            echo "Not found: $relpath" >&2
            exit 1
        fi
        if [ ! -d "$target" ]; then
            echo "Not a directory: $relpath (use 'read' for files)" >&2
            exit 1
        fi
        (cd "$target" && ls)
        ;;
    read)
        shift
        offset=""
        limit=""
        use_flags=false
        positionals=()
        while [ $# -gt 0 ]; do
            case "$1" in
                --offset)
                    if [ $# -lt 2 ]; then
                        echo "Error: --offset requires a line number" >&2
                        exit 1
                    fi
                    offset="$2"
                    use_flags=true
                    shift 2
                    ;;
                --limit)
                    if [ $# -lt 2 ]; then
                        echo "Error: --limit requires a line count" >&2
                        exit 1
                    fi
                    limit="$2"
                    use_flags=true
                    shift 2
                    ;;
                --)
                    shift
                    while [ $# -gt 0 ]; do
                        positionals+=("$1")
                        shift
                    done
                    ;;
                -*)
                    echo "Error: unsupported flag: $1" >&2
                    echo "Supported flags: --offset N, --limit M" >&2
                    exit 1
                    ;;
                *)
                    positionals+=("$1")
                    shift
                    ;;
            esac
        done
        if [ ${#positionals[@]} -eq 0 ]; then
            echo "Usage: viv-plugin-explore-monorepo read <relpath> [start] [end]" >&2
            echo "   or: viv-plugin-explore-monorepo read <relpath> [--offset N] [--limit M]" >&2
            exit 1
        fi
        relpath="${positionals[0]}"
        if [ "$use_flags" = true ] && [ ${#positionals[@]} -gt 1 ]; then
            echo "Error: cannot mix positional start/end with --offset/--limit flags" >&2
            exit 1
        fi
        if [ "$use_flags" = false ] && [ ${#positionals[@]} -gt 3 ]; then
            echo "Error: too many arguments. Usage: viv-plugin-explore-monorepo read <relpath> [start] [end]" >&2
            exit 1
        fi
        if [ "$use_flags" = true ]; then
            if [ -n "$offset" ] && ! [[ "$offset" =~ ^[0-9]+$ ]]; then
                echo "Invalid --offset: $offset (must be a positive integer)" >&2
                exit 1
            fi
            if [ -n "$limit" ] && ! [[ "$limit" =~ ^[0-9]+$ ]]; then
                echo "Invalid --limit: $limit (must be a positive integer)" >&2
                exit 1
            fi
            if [ -n "$offset" ] && [ -n "$limit" ]; then
                start="$offset"
                end=$((offset + limit - 1))
            elif [ -n "$offset" ]; then
                start="$offset"
                end=""
            else
                start="1"
                end="$limit"
            fi
        else
            start="${positionals[1]:-}"
            end="${positionals[2]:-}"
        fi
        validate_relpath "$relpath"
        target="$MONOREPO_DIR/$relpath"
        if [ ! -f "$target" ]; then
            echo "Not found: $relpath" >&2
            exit 1
        fi
        if [ -n "$start" ] && ! [[ "$start" =~ ^[0-9]+$ ]]; then
            echo "Invalid start line: $start (must be a positive integer)" >&2
            exit 1
        fi
        if [ -n "$end" ] && ! [[ "$end" =~ ^[0-9]+$ ]]; then
            echo "Invalid end line: $end (must be a positive integer)" >&2
            exit 1
        fi
        if [ -n "$start" ] && [ -n "$end" ] && [ "$start" -gt "$end" ]; then
            echo "Invalid range: start ($start) must be <= end ($end)" >&2
            exit 1
        fi
        if [ -n "$start" ] && [ -n "$end" ]; then
            sed -n "${start},${end}p" "$target"
        elif [ -n "$start" ]; then
            sed -n "${start},\$p" "$target"
        else
            cat "$target"
        fi
        ;;
    grep)
        shift
        grep_args=()
        positional=()
        while [ $# -gt 0 ]; do
            case "$1" in
                -A|-B)
                    if [ $# -lt 2 ]; then
                        echo "Error: $1 requires a numeric argument" >&2
                        exit 1
                    fi
                    if ! [[ "$2" =~ ^[0-9]+$ ]]; then
                        echo "Error: $1 requires a non-negative integer, got: $2" >&2
                        exit 1
                    fi
                    grep_args+=("$1" "$2")
                    shift 2
                    ;;
                -i|-l|-c)
                    grep_args+=("$1")
                    shift
                    ;;
                --)
                    shift
                    while [ $# -gt 0 ]; do
                        positional+=("$1")
                        shift
                    done
                    ;;
                -*)
                    echo "Error: unsupported flag: $1" >&2
                    echo "Supported flags: -A N, -B N, -i, -l, -c" >&2
                    exit 1
                    ;;
                *)
                    positional+=("$1")
                    shift
                    ;;
            esac
        done
        if [ ${#positional[@]} -eq 0 ]; then
            echo "Usage: viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]" >&2
            exit 1
        fi
        if [ ${#positional[@]} -gt 2 ]; then
            echo "Error: too many arguments. Usage: viv-plugin-explore-monorepo grep [flags] <pattern> [relpath]" >&2
            exit 1
        fi
        pattern="${positional[0]}"
        relpath="${positional[1]:-.}"
        validate_relpath "$relpath"
        target="$MONOREPO_DIR/$relpath"
        if [ ! -e "$target" ]; then
            echo "Not found: $relpath" >&2
            exit 1
        fi
        # Escape sed metacharacters in $MONOREPO_DIR (& \ and the | delimiter)
        # before using it in the substitution.
        escaped_dir=$(printf '%s' "$MONOREPO_DIR" | sed 's/[&\\|]/\\&/g')
        grep -rn ${grep_args[@]+"${grep_args[@]}"} -e "$pattern" "$target" 2>/dev/null | sed "s|${escaped_dir}/||" || true
        ;;
    *)
        echo "Unknown command: $1" >&2
        echo "Run viv-plugin-explore-monorepo --help for usage." >&2
        exit 1
        ;;
esac
