{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(vivc *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(python -m viv_compiler *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(poetry run vivc *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(pipx run viv-compiler *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(uv run vivc *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(python3 -m viv_compiler *)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Viv compiler auto-approved by plugin\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
