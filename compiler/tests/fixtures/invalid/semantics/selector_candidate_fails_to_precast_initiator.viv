// Invalid: selector candidate fails to precast initiator

reserved action respond:
    roles:
        @responder:
            as: initiator
        @witness:
            as: bystander

action wave:
    roles:
        @waver:
            as: initiator

action-selector pick:
    roles:
        @actor:
            as: initiator
    target randomly:
        respond:
            with partial:
                @witness: @actor
        ;
        wave;
